{
    "name": "asi/php-hooks",
    "description": "Simple hook system for PHP",
    "type": "library",
    "autoload": {
        "psr-4": {
            "Asi\\PhpHooks\\": "src/"
        }
    },
    "authors": [
        {
            "name": "asi developer"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "pestphp/pest": "^4.6"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
